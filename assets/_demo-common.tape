# Shared look & feel for the demo catalog. Not a standalone demo — Source'd by the demo-*.tape files.

Require uvx

Set Theme "Catppuccin Mocha"
Set FontFamily "MesloLGL Nerd Font"   # any installed Nerd Font; emoji via system fallback
Set FontSize 22
Set Width 1280
Set Height 460
Set Padding 40
Set Margin 24
Set MarginFill "#1e1e2e"
Set BorderRadius 14
Set WindowBar Colorful
Set TypingSpeed 45ms
